### =====================================================
### GET USERS (ADMIN ONLY)
### =====================================================

GET {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}

### =====================================================
### ADD VEHICLE
### =====================================================

POST {{baseUrl}}/api/vehicles
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "user_id": 1,
  "vehicle_number": "TS05EL9999",
  "vehicle_type": "Bike",
  "vehicle_brand": "Yamaha",
  "vehicle_model": "150",
  "vehicle_color": "Black"
}

### =====================================================
### GET USER VEHICLES
### =====================================================

GET {{baseUrl}}/api/vehicles/user/1
Authorization: Bearer {{customerToken}}

### =====================================================
### GET PARKING SLOTS
### =====================================================

GET {{baseUrl}}/api/parking/slots
Authorization: Bearer {{customerToken}}

### =====================================================
### CREATE RESERVATION
### =====================================================

POST {{baseUrl}}/api/reservations
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "user_id": 1,
  "vehicle_id": 4,
  "slot_id": 1,
  "reservation_date": "2026-05-25",
  "start_time": "18:00",
  "expected_end_time": "21:00"
}

### =====================================================
### GET RESERVATION HISTORY
### =====================================================

GET {{baseUrl}}/api/reservations/history/1
Authorization: Bearer {{customerToken}}

### =====================================================
### CHECK-IN
### =====================================================

POST {{baseUrl}}/api/parking/checkin
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "reservation_code": "RSV-20260525-U5-1234"
}

### =====================================================
### ACTIVE PARKING SESSIONS
### =====================================================

GET {{baseUrl}}/api/parking/active
Authorization: Bearer {{staffToken}}

### =====================================================
### CHECKOUT
### =====================================================

POST {{baseUrl}}/api/parking/checkout
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "parking_id": "PK-20260525-2"
}

### =====================================================
### GET PAYMENT DETAILS
### =====================================================

GET {{baseUrl}}/api/payments/PAY-20260523-1
Authorization: Bearer {{customerToken}}

### =====================================================
### PAY NOW
### =====================================================

POST {{baseUrl}}/api/payments/pay
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "payment_code": "PAY-20260523-1",
  "payment_method": "UPI"
}

### =====================================================
### PAYMENT HISTORY
### =====================================================

GET {{baseUrl}}/api/payments/history/1
Authorization: Bearer {{customerToken}}

### =====================================================
### PARKING HISTORY
### =====================================================

GET {{baseUrl}}/api/parking/history/1
Authorization: Bearer {{customerToken}}

### =====================================================
### USER NOTIFICATIONS
### =====================================================

GET {{baseUrl}}/api/notifications/1
Authorization: Bearer {{customerToken}}

### =====================================================
### DASHBOARD ANALYTICS (ADMIN ONLY)
### =====================================================

GET {{baseUrl}}/api/dashboard/parking
Authorization: Bearer {{adminToken}}